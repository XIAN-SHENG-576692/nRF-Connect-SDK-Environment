{
  "containerUser": "root",

  "customizations": {
    "vscode": {
      "extensions": [
        "cschlosser.doxdocgen",
        "eamodio.gitlens",
        "formulahendry.code-runner",
        "github.vscode-github-actions",
        "marus25.cortex-debug",
        "ms-vscode.makefile-tools",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "nordic-semiconductor.nrf-connect",
        "nordic-semiconductor.nrf-connect-extension-pack",
        "nordic-semiconductor.nrf-devicetree",
        "nordic-semiconductor.nrf-kconfig",
        "nordic-semiconductor.nrf-terminal",
        "usernamehw.errorlens"
      ],
      "settings": {
        "C_Cpp.default.configurationProvider": "nordic-semiconductor.nrf-connect",
        "cmake.sourceDirectory": "${workspaceFolder}"
      }
    }
  },

  "dockerComposeFile": [
    "docker-compose.yml"
  ],

  "overrideCommand": true,

  "service": "dev",

  "updateRemoteUserUID": true,  // Match container user UID/GID with host to prevent permission issues

  "workspaceFolder": "/work/ncs/app"
}
